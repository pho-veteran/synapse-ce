# Synapse configuration – copy to `.env` and adjust. NEVER commit real secrets.
#
# Synapse reads the PROCESS ENVIRONMENT directly; it does NOT auto-load this file.
# Load it into your shell first:   set -a; source .env; set +a
# (or pass it via Docker --env-file / Compose env_file / your process manager).
#
# Conventions: empty value = unset (the built-in default applies); booleans accept
# 1/0/true/false; durations use Go syntax (30s, 10m, 1h); sizes are byte counts.
# Values shown below are the defaults unless noted. Commented lines document an
# option without enabling it. Full reference: README.md → Configuration.

# =============================================================================
# REQUIRED before the server will start
# =============================================================================
# Bootstrap-admin bearer token – the API exits if this is empty (no anonymous
# access). Generate one:  openssl rand -hex 32
SYNAPSE_API_TOKEN=

# =============================================================================
# Core / server
# =============================================================================
SYNAPSE_HTTP_ADDR=:8080
# Deployment env. Non-prod: development|dev|local|test|ci. ANYTHING ELSE (incl.
# typos, "staging", "production") is treated as production and enables the strict,
# fail-closed gates (vault key + signing seed + sandbox become mandatory).
SYNAPSE_ENV=development
SYNAPSE_LOG_LEVEL=info
SYNAPSE_SINGLE_TENANT=true
# Acceptable-Use Policy version operators must accept on first run.
SYNAPSE_AUP_VERSION=1.0
# File-backed paths used only in in-memory mode (no SYNAPSE_DB_DSN).
SYNAPSE_AUP_FILE=data/aup-accepted.json
SYNAPSE_AUDIT_FILE=data/audit.jsonl

# =============================================================================
# Persistence – PostgreSQL (empty DSN ⇒ in-memory dev store; nothing durable)
# =============================================================================
# The `make docker-up` stack uses user, password, and database all set to "synapse";
# put the user + password into the userinfo slot of the URL, e.g.
#   postgres://USER:PASSWORD@localhost:5432/synapse?sslmode=disable
SYNAPSE_DB_DSN=postgres://localhost:5432/synapse?sslmode=disable
# pgx connection-pool sizing.
# SYNAPSE_DB_MAX_CONNS=32
# SYNAPSE_DB_MIN_CONNS=0
# SYNAPSE_DB_MAX_CONN_LIFETIME=1h
# SYNAPSE_DB_MAX_CONN_IDLE=30m

# =============================================================================
# Evidence blob store – MinIO / S3 (empty endpoint ⇒ in-memory dev store)
# =============================================================================
# Endpoint is host:port WITHOUT a scheme; set USE_SSL=true for https.
# Values below match the `make docker-up` MinIO.
SYNAPSE_BLOB_ENDPOINT=localhost:9000
SYNAPSE_BLOB_ACCESS_KEY=synapse
SYNAPSE_BLOB_SECRET_KEY=synapse-secret
SYNAPSE_BLOB_BUCKET=synapse-evidence
SYNAPSE_BLOB_USE_SSL=false

# =============================================================================
# Custody, signing & anchoring  (the two keys are REQUIRED in production)
# =============================================================================
# AES-256 credential-vault master key: 64 hex chars or base64 of 32 bytes.
# Empty ⇒ ephemeral dev key (stored secrets do NOT survive a restart). Never logged.
SYNAPSE_VAULT_MASTER_KEY=
# ed25519 seed attesting evidence + audit chain heads (stable key id across restarts).
# Empty ⇒ ephemeral key. Never logged.
SYNAPSE_EVIDENCE_SIGNING_SEED=
# RFC-3161 timestamp authority for external anchoring (tamper-PROOF). Empty ⇒
# signed-but-not-anchored (still tamper-evident).
# SYNAPSE_TSA_URL=

# =============================================================================
# Software Composition Analysis
# =============================================================================
# SBOM producer: "syft" (pinned binary, full coverage + dep-graph edges) or
# "ownsbom" (detection-independent owned parsers; components-only).
SYNAPSE_SBOM_PRODUCER=syft
# Tool binaries (resolved on PATH by default).
# SYNAPSE_SYFT_BIN=syft
# SYNAPSE_GRYPE_BIN=grype           # missing ⇒ degrades to OSV-only
# Pin Grype's vuln DB to a pre-synced dir for offline + reproducible scans (empty ⇒ online).
# SYNAPSE_GRYPE_DB_DIR=
# Per-scan timeout (0 disables) and the lowest severity promoted to a finding.
# SYNAPSE_SCAN_TIMEOUT=10m
# SYNAPSE_FINDING_MIN_SEVERITY=high   # critical|high|medium|low|info
# Max total size of a prepared scan workspace (bytes); a bigger target/archive is rejected.
# Lower for CI, raise for a large monorepo. <=0 keeps the 2 GiB default.
# SYNAPSE_MAX_WORKSPACE_BYTES=2147483648
# Match the SBOM against the owned advisory store (offline) alongside OSV/Grype.
# ON by default; a no-op until you populate it:  synapse-cli sync-advisories <dir>|--remote|--csaf <dir>
SYNAPSE_OWNED_ADVISORY=true
# Feed overrides (tests / mirrors); empty ⇒ public endpoints.
# SYNAPSE_OSV_URL=
# SYNAPSE_OSV_BULK_URL=
# SYNAPSE_DEPSDEV_URL=
# SYNAPSE_KEV_URL=
# SYNAPSE_EPSS_URL=

# =============================================================================
# Scanning capabilities  (ON by default – set a flag to false to opt out)
# =============================================================================
# Every deterministic, best-effort analysis capability is ON by default so the
# tool is fully effective out of the box (the UI and a bare scan get the full
# feature set). Each is a no-op when its input is absent. Set =false to disable.
#
# Secret scanning: regex + entropy over the workspace; matches are redacted.
SYNAPSE_SECRET_SCAN_ENABLED=true
# Misconfiguration / IaC scanning: Dockerfile + Kubernetes manifests.
SYNAPSE_MISCONFIG_ENABLED=true
# Compliance benchmark: re-project findings onto a control spec (PASS/FAIL).
SYNAPSE_COMPLIANCE_ENABLED=true
# Honor a repo .synapseignore accepted-risk file (retain-and-mark; gate-exempt only).
SYNAPSE_SUPPRESSION_ENABLED=true
# Consume an in-repo OpenVEX doc (.synapse.vex.json) at scan time.
SYNAPSE_VEX_ENABLED=true
# Container image rootfs: materialize the image FS so the owned OS-package
# catalogers (dpkg/apk + rpm sqlite rpmdb) and installed-binary catalogers
# (Go buildinfo, Python dist-info) can run. Best-effort; image scans only.
SYNAPSE_IMAGE_ROOTFS_ENABLED=true
# SBOM scan cache: content + producer-version addressed; skips re-cataloging an
# unchanged tree. The cache dir MUST be operator-owned (per-user default is safe).
SYNAPSE_SCAN_CACHE_ENABLED=true
# SYNAPSE_SCAN_CACHE_DIR=            # empty ⇒ a per-user cache location
# (Pattern SAST + the judgment analyzers are in the "Analysis brain" section below.)
#
# Detection tuning – the defaults are already the thorough choice:
# comprehensive (default) reports every match; precise quarantines single-source
# non-KEV findings into a needs-verify queue (still reported + sealed, gate-exempt).
# SYNAPSE_DETECTION_PRIORITY=comprehensive   # comprehensive|precise
# Warn when a dated reference DB (KEV/EPSS/Grype) is older than N days (0 disables).
# SYNAPSE_DB_MAX_AGE_DAYS=30
# Skip the live advisory source; detect offline only (off = more recall).
# SYNAPSE_OFFLINE=false
# Drop vulnerabilities with no fixed version (off = show everything).
# SYNAPSE_IGNORE_UNFIXED=false

# =============================================================================
# Recon & execution sandbox  (sandbox is REQUIRED in production)
# =============================================================================
# Run tool execution + acquisition in the bubblewrap sandbox. If set but
# bubblewrap is unavailable, startup FAILS CLOSED (never runs unsandboxed).
SYNAPSE_SANDBOX_ENABLED=false
# Per-run cgroup limits (bytes / pid count).
# SYNAPSE_SANDBOX_MEM_MAX=536870912    # 512 MiB
# SYNAPSE_SANDBOX_PIDS_MAX=256
# Authoritative sha256 pins "name=hex,/abs/path=hex,…"; the sandbox refuses a
# binary whose hash doesn't match. Empty ⇒ trust-on-first-use.
# SYNAPSE_TOOL_HASHES=
# Recon worker pool + per-run bounds.
# SYNAPSE_RECON_TIMEOUT=3m
# SYNAPSE_RECON_MAX_OUTPUT=8388608     # 8 MiB
# SYNAPSE_RECON_CONCURRENCY=3
# SYNAPSE_RECON_QUEUE=64
# Permit capability-sensitive tools (e.g. naabu / raw sockets).
# SYNAPSE_RECON_ALLOW_CAPABILITY_SENSITIVE=false
# Route recon through the durable queue to synapse-worker (requires Postgres).
# SYNAPSE_RECON_VIA_WORKER=false

# =============================================================================
# AI agent orchestration  (off by default)
# =============================================================================
# SYNAPSE_AGENT_ENABLED=false
# OpenAI-compatible Chat Completions endpoint + credentials. The key is never logged.
# SYNAPSE_LLM_BASE_URL=http://localhost:20128/v1
# SYNAPSE_LLM_API_KEY=
# SYNAPSE_LLM_MODEL=                   # REQUIRED when the agent is enabled
# SYNAPSE_LLM_TIMEOUT=60s
# Adversarial finding verifier model (defaults to SYNAPSE_LLM_MODEL).
# SYNAPSE_VERIFIER_MODEL=
# HITL approval: manual (human approves every action) | filter | auto.
# SYNAPSE_AGENT_APPROVAL_MODE=manual
# SYNAPSE_AGENT_APPROVAL_TIMEOUT=30m   # fail-closed timeout
# Per-run bounds.
# SYNAPSE_AGENT_MAX_STEPS=16
# SYNAPSE_AGENT_TOKEN_BUDGET=0         # 0 = unbounded
# SYNAPSE_AGENT_MAX_DURATION=10m
# Durable agent on synapse-worker (requires SYNAPSE_RECON_VIA_WORKER + Postgres).
# SYNAPSE_AGENT_VIA_WORKER=false
# Inline-agent admission + plan-DAG parallelism.
# SYNAPSE_AGENT_CONCURRENCY=8
# SYNAPSE_AGENT_QUEUE_DEPTH=256        # over ⇒ 503
# SYNAPSE_AGENT_MAX_PARALLEL=1         # in-flight plan nodes (serial by default)
# SYNAPSE_AGENT_RECON_CONCURRENCY=3
# SYNAPSE_APPROVAL_SWEEP_INTERVAL=1m

# =============================================================================
# Analysis brain  (deterministic parts ON by default; the parts needing the
# sandbox or the agent stay opt-in – all are best-effort, no-op without inputs)
# =============================================================================
# JUDGMENTS_ENABLED is the prerequisite for the analyzers that mint judgments;
# it and the deterministic analyzers default ON. Set a flag =false to opt out.
SYNAPSE_JUDGMENTS_ENABLED=true       # judgment lifecycle routes (verify/accept/list)
SYNAPSE_SAST_ENABLED=true            # pattern-SAST in the scan pipeline
SYNAPSE_REACHABILITY_ENABLED=true    # Tier-2 call-graph reachability proof (govulncheck; best-effort)
SYNAPSE_CROSSCHECK_ENABLED=true      # detection-source disagreement judgments
SYNAPSE_SBOM_CROSSCHECK_ENABLED=true # dual-producer SBOM cross-check
SYNAPSE_GOMODGRAPH_ENABLED=true      # transitive Go dep edges via `go mod graph`
# SYNAPSE_GOVULNCHECK_BIN=govulncheck
# SYNAPSE_GO_BIN=go
# Opt-in – these need external setup:
# SYNAPSE_TAINT_ENABLED=false          # taint CapSAST proposals – needs Judgments + the sandbox
# SYNAPSE_TAINT_CALLGRAPH_BIN=synapse-callgraph
# SYNAPSE_WRITEUP_DRAFTS_ENABLED=false # agent propose_writeup_draft tool – needs the agent

# =============================================================================
# MCP server (synapse-mcp) – read + propose-only; never executes
# =============================================================================
# Both are REQUIRED to start synapse-mcp. The token is never logged.
# SYNAPSE_MCP_TOKEN=
# SYNAPSE_MCP_ENGAGEMENT_ID=
# SYNAPSE_MCP_ADDR=:8081
